# ─────────────────────────────────────────────
# LLM — Amazon Bedrock (IAM auth only, no keys)
# Credentials via: AWS_PROFILE, instance profile, or ECS task role
# ─────────────────────────────────────────────
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_FAST_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_TEMPERATURE=0.2

# Optional: Bedrock Guardrails
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT

# AWS profile (if not using instance profile or ECS task role)
# AWS_PROFILE=my-profile

# ─────────────────────────────────────────────
# Knowledge repo — your project's SOPs, ADDs, ADRs (OKF format)
# Stored in ~/code-crew/repos/ by default (not in the project directory)
# ─────────────────────────────────────────────

# Git URL of your knowledge/designs repo. Cloned to ~/code-crew/repos/designs/
# on first run, then pulled on every subsequent run.
DESIGNS_REPO=git@github.com:your-org/designs.git
DESIGNS_BRANCH=main

# Override the local clone path (default: ~/code-crew/repos/designs)
# DESIGNS_PATH=~/code-crew/repos/designs

# Override the Definition of Done file path (absolute or relative to DESIGNS_PATH)
# DOD_PATH=SOP/SOP-DoD-Definition-of-Done.md

# ─────────────────────────────────────────────
# Platform / codebase
# ─────────────────────────────────────────────
# Path to the codebase the crew works on (git, test, grep commands run here)
PLATFORM_PATH=../platform

# Jira project key
JIRA_PROJECT=LOOPLAT

# Jira REST API credentials (required for `code-crew sprint --sprint "Sprint 5"`)
# Get your token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_URL=https://yourorg.atlassian.net
# JIRA_USER=you@yourorg.com
# JIRA_TOKEN=your-api-token
