# ─────────────────────────────────────────────────────────────────────────────
# code-crew configuration
#
# Global config lives at ~/.code-crew/config (shared across all projects).
# Copy this file there:
#
#   cp .env.example ~/.code-crew/config
#
# Named profiles live at ~/.code-crew/profiles/<name>.env
# They override global config. Activate with:
#   export CODE_CREW_PROFILE=<name>   — in your shell
#   CODE_CREW_PROFILE=<name> code-crew
#   profile: <name>                   — in project .code-crew.yaml
#   /profile <name>                   — in the REPL (switches live)
#
# Project-specific settings (JIRA_URL, PROJECT_KEY, etc.) can also live
# in a local .env in the project root — loaded last, highest precedence.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# LLM — Amazon Bedrock (IAM auth only, no keys)
# Credentials via: AWS_PROFILE, instance profile, or ECS task role
# ─────────────────────────────────────────────
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_FAST_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_POWERFUL_MODEL_ID=us.anthropic.claude-opus-4-8-20260101-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_TEMPERATURE=0.2

# Optional: Bedrock Guardrails
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT

# AWS profile (if not using instance profile or ECS task role)
# AWS_PROFILE=my-profile

# ─────────────────────────────────────────────
# Knowledge repo — your project's SOPs, ADDs, ADRs (OKF format)
# Stored in ~/.code-crew/repos/ by default
# ─────────────────────────────────────────────

# Git URL of your knowledge/designs repo. Cloned to ~/.code-crew/repos/designs/
# on first run, then pulled on every subsequent run.
DESIGNS_REPO=git@github.com:your-org/designs.git
DESIGNS_BRANCH=main

# Override the local clone path (default: ~/.code-crew/repos/designs)
# DESIGNS_PATH=~/.code-crew/repos/designs

# Override the Definition of Done file path (absolute or relative to DESIGNS_PATH)
# DOD_PATH=SOP/SOP-DoD-Definition-of-Done.md

# ─────────────────────────────────────────────
# Issue tracker
# ─────────────────────────────────────────────
# Issue tracker to use: jira (default) or linear
ISSUE_TRACKER=jira

# Project key (Jira project key or Linear team identifier)
PROJECT_KEY=PROJ

# Jira REST API credentials (required for sprint listing)
# Get your token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_URL=https://yourorg.atlassian.net
# JIRA_USER=you@yourorg.com
# JIRA_TOKEN=your-api-token

# ─────────────────────────────────────────────
# Tech stack override
# Comma-separated list of stack names. When set, overrides both .code-crew.yaml
# and file-based auto-detection. Useful in profiles for client-specific stacks.
# Known values: go-backend, typescript-react, python, terraform-aws
# ─────────────────────────────────────────────
# CODE_CREW_STACKS=python,typescript-react

# ─────────────────────────────────────────────
# Flow behaviour
# ─────────────────────────────────────────────
# Max retries per review gate before escalating to human
MAX_RETRIES=3
