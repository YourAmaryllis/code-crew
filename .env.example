# Amazon Bedrock — IAM auth only (no API keys)
# Credentials via: AWS_PROFILE, instance profile, or ECS task role
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20251001-v2:0
BEDROCK_FAST_MODEL_ID=anthropic.claude-haiku-4-5-20251001
BEDROCK_REGION=us-east-1
BEDROCK_TEMPERATURE=0.2

# Optional: Bedrock Guardrails
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT

# Platform monorepo path (default: ../platform relative to tools/)
PLATFORM_PATH=../platform

# Jira project key (default: LOOPLAT)
JIRA_PROJECT=LOOPLAT

# Optional: override designs submodule path (default: tools/designs/)
# DESIGNS_PATH=/absolute/path/to/designs

# Optional: override user memory file path (default: ~/.youramaryllis/crew-memory.jsonl)
# CREW_MEMORY_PATH=~/.youramaryllis/crew-memory.jsonl

# AWS profile (if not using instance profile or ECS task role)
# AWS_PROFILE=youramaryllis-dev
